            "title": "Linux Journey",
            "url": "https://linuxjourney.com/",
            "type": "course"
          }
        ]
      }
    },
    {
      "id": "shell",
      "type": "topic",
      "position": {
        "x": 440,
        "y": 200
      },
      "data": {
        "label": "Shell Scripting",
        "status": "recommended",
        "description": "Automate repetitive tasks with Bash scripting. Learn variables, loops, conditionals, pipes, and cron jobs.",
        "resources": [
          {
            "title": "Bash Scripting Tutorial",
            "url": "https://www.freecodecamp.org/news/bash-scripting-tutorial-linux-shell-script-and-command-line-for-beginners/",
