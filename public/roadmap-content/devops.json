          }
        ]
      }
    },
    {
      "id": "net",
      "type": "topic",
      "position": {
        "x": 440,
        "y": 300
      },
      "data": {
        "label": "Networking & Security",
        "status": "recommended",
        "description": "Learn DNS, HTTP/S, firewalls, VPNs, load balancers, reverse proxies (Nginx), and SSL certificate management.",
