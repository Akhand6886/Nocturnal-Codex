      },
      "data": {
        "label": "Operating Systems",
        "status": "recommended",
        "description": "Understand Linux administration, process management, file systems, and system calls. Linux is the backbone of DevOps.",
        "resources": [
          {
            "title": "Linux Administration Handbook",
            "url": "https://www.oreilly.com/library/view/unix-and-linux/9780134278308/",
