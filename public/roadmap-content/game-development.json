      },
      "data": {
        "label": "Game Developer"
      }
    },
    {
      "id": "lang",
      "type": "topic",
      "position": {
        "x": 440,
        "y": 100
      },
      "data": {
        "label": "Language Selection",
        "status": "recommended",
        "description": "Learn the languages powering modern game engines: C++ (high-performance AAA games) or C# (versatile indie games).",
        "resources": [
          {
            "title": "C++ for Game Dev",
            "url": "https://www.youtube.com/watch?v=18c3MTX0PK0",
            "type": "video"
          },
          {
            "title": "C# Fundamentals",
            "url": "https://learn.microsoft.com/en-us/dotnet/csharp/",
            "type": "docs"
          }
        ]
      }
    },
    {
      "id": "engines",
      "type": "topic",
      "position": {
        "x": 440,
        "y": 200
      },
      "data": {
        "label": "Choose Your Engine",
        "status": "recommended",
        "description": "Select an engine that suits your game scope. Unity is great for 2D/3D & mobile, Unreal for high-end graphics, and Godot for open-source simplicity.",
        "resources": [
          {
            "title": "Unity Learning Paths",
            "url": "https://learn.unity.com/",
            "type": "course"
          },
          {
            "title": "Unreal Engine Docs",
            "url": "https://docs.unrealengine.com/",
            "type": "docs"
          },
          {
            "title": "Godot Engine Docs",
            "url": "https://docs.godotengine.org/",
            "type": "docs"
          }
        ]
      }
    },
    {
      "id": "game_loop",
      "type": "topic",
      "position": {
        "x": 440,
        "y": 300
      },
      "data": {
        "label": "Game Loop & Input",
        "status": "recommended",
        "description": "Understand core real-time application mechanics: mapping inputs, processing gameplay logic, and updating frames.",
        "resources": [
          {
            "title": "Game Programming Patterns - Game Loop",
            "url": "https://gameprogrammingpatterns.com/game-loop.html",
            "type": "article"
          }
        ]
      }
    },
    {
      "id": "math",
      "type": "topic",
      "position": {
        "x": 440,
        "y": 400
      },
      "data": {
        "label": "Math & Physics",
        "status": "recommended",
        "description": "Master trigonometry, linear algebra (vectors, matrices, quaternions), rigidbodies, and collision detection formulas.",
        "resources": [
          {
            "title": "Mathematics for Game Developers",
            "url": "https://www.youtube.com/playlist?list=PLW3Zl3wyJwWOpDHHPvcjDWKdiFQWDxssR",
            "type": "course"
          }
        ]
      }
    },
    {
      "id": "graphics",
      "type": "topic",
      "position": {
        "x": 440,
        "y": 500
      },
      "data": {
        "label": "Graphics & Shaders",
        "status": "recommended",
        "description": "Learn rendering pipelines, lighting nodes, post-processing materials, and how to write shaders (HLSL/GLSL).",
        "resources": [
          {
            "title": "The Book of Shaders",
            "url": "https://thebookofshaders.com/",
            "type": "docs"
          }
        ]
      }
    },
    {
      "id": "opt",
      "type": "topic",
      "position": {
        "x": 440,
        "y": 600
      },
      "data": {
        "label": "Optimization",
        "description": "Use object pooling, asset optimization, dynamic batching, and code profiling tools to sustain target frame rates.",
        "resources": [
          {
            "title": "Unity Optimization Guide",
            "url": "https://unity.com/resources/ultimate-guide-to-profiling-unity-games",
            "type": "docs"
          }
        ]
      }
    },
    {
      "id": "unreal",
      "type": "subtopic",
      "position": {
        "x": 200,
        "y": 150
      },
      "data": {
        "label": "Unreal Engine (C++)",
        "status": "recommended",
        "description": "Developing high-fidelity, performance-critical games in Unreal Engine using C++ and blueprints.",
        "resources": [
          {
            "title": "Unreal Engine C++ Developer Course",
            "url": "https://www.gamedev.tv/p/unreal-c-developer",
            "type": "course"
          },
          {
            "title": "Unreal Engine Documentation",
            "url": "https://docs.unrealengine.com/",
            "type": "docs"
          }
        ]
      }
    },
    {
      "id": "unity",
      "type": "subtopic",
      "position": {
        "x": 200,
        "y": 200
      },
      "data": {
        "label": "Unity Engine (C#)",
        "status": "recommended",
        "description": "Developing cross-platform 2D/3D games in Unity Engine using C# scripting.",
        "resources": [
          {
            "title": "Unity Learn platform",
            "url": "https://learn.unity.com/",
            "type": "course"
          },
          {
            "title": "C# Scripting in Unity",
            "url": "https://docs.unity3d.com/Manual/CreatingAndUsingScripts.html",
            "type": "docs"
          }
        ]
      }
    },
    {
      "id": "godot",
      "type": "subtopic",
      "position": {
        "x": 200,
        "y": 250
      },
      "data": {
        "label": "Godot Engine",
        "status": "alternative",
        "description": "Using the lightweight, open-source 2D and 3D game engine Godot with GDScript or C#.",
        "resources": [
          {
            "title": "Godot Engine Official Docs",
            "url": "https://docs.godotengine.org/",
            "type": "docs"
          },
          {
            "title": "Godot Tutorials - FreeCodeCamp",
            "url": "https://www.youtube.com/watch?v=LOhfqjmasI0",
            "type": "video"
          }
        ]
      }
    },
    {
      "id": "vectors",
      "type": "subtopic",
      "position": {
        "x": 700,
        "y": 380
      },
      "data": {
        "label": "Vectors & Trigonometry",
        "status": "recommended",
        "description": "The math behind physics, translation, rotation, dot products, cross products, and geometry in game space.",
        "resources": [
          {
            "title": "Math for Game Developers - Freya Holm\u00e9r",
            "url": "https://www.youtube.com/watch?v=MOYiVLE9jhg",
            "type": "video"
          }
        ]
      }
    },
    {
      "id": "raycast",
      "type": "subtopic",
      "position": {
        "x": 700,
        "y": 425
      },
      "data": {
        "label": "Collisions & Raycasting",
        "status": "recommended",
        "description": "Detecting overlaps, physical intersections, bounding boxes, grid alignment, and drawing line-of-sight laser queries (raycasts).",
        "resources": [
          {
            "title": "Game Physics & Collisions",
            "url": "https://developer.mozilla.org/en-US/docs/Games/Techniques/2D_collision_detection",
            "type": "article"
          }
        ]
      }
    },
    {
      "id": "shaders",
      "type": "subtopic",
      "position": {
        "x": 700,
        "y": 500
      },
      "data": {
        "label": "HLSL / GLSL Shaders",
        "status": "recommended",
        "description": "High-Level Shading Language (DirectX) and OpenGL Shading Language, used to write custom rendering behaviors for the GPU.",
        "resources": [
          {
            "title": "The Book of Shaders",
            "url": "https://thebookofshaders.com/",
            "type": "course"
          },
          {
            "title": "Shaders in Unity Guide",
            "url": "https://docs.unity3d.com/Manual/Shaders.html",
            "type": "docs"
          }
        ]
      }
    }
